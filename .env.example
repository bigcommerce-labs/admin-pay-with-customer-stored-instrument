# BigCommerce App credentials (from Developer Portal → your app)
BIGCOMMERCE_APP_CLIENT_ID=
BIGCOMMERCE_APP_CLIENT_SECRET=

# Public URL of this app (your ngrok HTTPS URL during local dev)
APP_URL=https://your-subdomain.ngrok-free.app

# Signing key for app-session JWT cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_KEY=

# Optional: override for local testing; leave blank in prod
# APP_EXTENSION_LABEL="Pay with customer saved payments"
